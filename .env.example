# Database connection for Prisma
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Shadow database connection for Prisma Migrations
SHADOW_NAME=
SHADOW_HOST=
SHADOW_PORT=
SHADOW_USER=
SHADOW_PASSWORD=

# Contact Email
CONTACT_EMAIL_TO=you@example.com
CONTACT_EMAIL_FROM=website@example.com
CONTACT_IP_HASH_SECRET=replace-with-a-long-random-secret

# SMTP Config
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Admin Area
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret